    <Style src="project://database/Assets/UI/NationSelection.uss" />

    <ui:VisualElement name="nation-selection-root" class="nation-selection-root">
        <ui:Label text="选择你的国家" class="nation-selection-title" />
        <ui:VisualElement name="nation-card-container" class="nation-card-container" />
    </ui:VisualElement>
</ui:UXML>
